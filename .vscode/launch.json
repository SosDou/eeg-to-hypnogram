{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: EDF Reader Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/edf_reader_test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "启用 GDB STL 格式化",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "使用 Intel 汇编语法",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug: EDF Reader Integration Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/edf_reader_test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "EEG_TEST_EDF_FILE",
                    "value": "${workspaceFolder}/datasets/physionet-sleep-data/SC4001E0-PSG.edf"
                },
                {
                    "name": "EEG_TEST_HYPNOGRAM_FILE",
                    "value": "${workspaceFolder}/datasets/physionet-sleep-data/SC4001EC-Hypnogram.edf"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "启用 GDB STL 格式化",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "使用 Intel 汇编语法",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}